# AssetFlow Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values. NEVER commit .env to git.

PORT=5000

# PostgreSQL / Supabase connection string
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT — generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Express payload limit
REQUEST_PAYLOAD_LIMIT=1mb

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
