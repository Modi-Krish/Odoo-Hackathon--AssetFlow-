# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/assetflow
# Required if using Supabase or pooling
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# API Security
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
CORS_ORIGIN=http://localhost:3000

# Next.js Frontend Config
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_DEFAULT_PASSWORD=password123

# Cloud Provider Keys (Placeholders)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# SMTP / Email Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Rate Limiting
REQUEST_PAYLOAD_LIMIT=1mb
